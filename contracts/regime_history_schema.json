{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-ai/contracts/regime_history_schema.json",
  "title": "Regime History Tracker Persistence Format",
  "type": "object",
  "required": ["schema_version", "generated_at", "entries"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "primary_regime",
          "secondary_regime",
          "confidence",
          "cpi",
          "capital",
          "pipeline",
          "flip_trigger",
          "duration_days",
          "status"
        ],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "primary_regime": { "type": "string" },
          "secondary_regime": { "type": ["string", "null"] },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "cpi": { "type": "number", "minimum": 0, "maximum": 100 },
          "capital": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "pipeline": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "flip_trigger": { "type": ["string", "null"] },
          "duration_days": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["Active", "Closed"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
