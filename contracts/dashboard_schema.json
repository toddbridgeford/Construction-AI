{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-ai/contracts/dashboard_schema.json",
  "title": "Construction AI Dashboard Contract",
  "description": "Canonical contract for dashboard_latest.json consumed by ChatGPT, Notion automations, and Swift Playgrounds clients.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "executive",
    "cpi",
    "volatility_regime",
    "regime_history",
    "regime_history_display",
    "ui"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "executive": {
      "type": "object",
      "required": ["headline", "confidence", "summary"],
      "properties": {
        "headline": { "type": "string", "minLength": 1 },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "cpi": {
      "type": "object",
      "required": ["headline", "zone", "delta_3m", "momentum", "history", "components"],
      "properties": {
        "headline": { "type": "number", "minimum": 0, "maximum": 100 },
        "zone": { "type": "string" },
        "delta_3m": { "type": "number" },
        "momentum": { "type": "string" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "value"],
            "properties": {
              "date": { "type": "string", "format": "date" },
              "value": { "type": "number", "minimum": 0, "maximum": 100 }
            },
            "additionalProperties": false
          }
        },
        "components": {
          "type": "object",
          "required": ["capital", "pipeline", "trade", "materials", "regulatory", "macro_sentiment"],
          "properties": {
            "capital": { "type": "number", "minimum": 0, "maximum": 100 },
            "pipeline": { "type": "number", "minimum": 0, "maximum": 100 },
            "trade": { "type": "number", "minimum": 0, "maximum": 100 },
            "materials": { "type": "number", "minimum": 0, "maximum": 100 },
            "regulatory": { "type": "number", "minimum": 0, "maximum": 100 },
            "macro_sentiment": { "type": "number", "minimum": 0, "maximum": 100 },
            "overlays": {
              "type": "object",
              "properties": {
                "stock_overlay": { "type": "number" },
                "news_pressure_overlay": { "type": "number" },
                "energy_overlay": { "type": "number" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "volatility_regime": { "type": "string" },
    "regime_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "primary_regime",
          "secondary_modifier",
          "confidence",
          "cpi_level",
          "capital_score",
          "pipeline_score",
          "flip_trigger",
          "duration_days",
          "status"
        ],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "primary_regime": { "type": "string" },
          "secondary_modifier": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "cpi_level": { "type": "number", "minimum": 0, "maximum": 100 },
          "capital_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "pipeline_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
          "flip_trigger": { "type": ["string", "null"] },
          "duration_days": { "type": ["integer", "null"], "minimum": 0 },
          "status": { "type": "string", "enum": ["Active", "Closed"] }
        },
        "additionalProperties": false
      }
    },
    "regime_history_display": {
      "type": "object",
      "required": ["current_regime_duration_days", "previous_regime", "last_flip_date", "regime_stability"],
      "properties": {
        "current_regime_duration_days": { "type": ["integer", "null"], "minimum": 0 },
        "previous_regime": { "type": ["string", "null"] },
        "last_flip_date": { "type": ["string", "null"], "format": "date" },
        "regime_stability": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "required": ["alerts", "trends", "cards", "heat_strip"],
      "properties": {
        "alerts": { "type": "array" },
        "trends": { "type": "object" },
        "cards": { "type": "array" },
        "heat_strip": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
