{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-ai.local/schemas/artifacts_schema.json",
  "title": "Artifact Feed Schema",
  "type": "object",
  "required": ["version", "market", "generated_at", "artifact_type", "records"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "market": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "artifact_type": {
      "type": "string",
      "enum": ["bid_calendar", "contacts"]
    },
    "source": {
      "type": "object",
      "required": ["input_file"],
      "properties": {
        "input_file": { "type": "string", "minLength": 1 },
        "project_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "records": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "project_id",
              "project_name",
              "stage",
              "estimated_bid_date",
              "bid_window_days",
              "confidence"
            ],
            "properties": {
              "project_id": { "type": "string", "minLength": 1 },
              "project_name": { "type": "string", "minLength": 1 },
              "stage": { "type": "string", "minLength": 1 },
              "estimated_bid_date": {
                "oneOf": [
                  { "type": "string", "format": "date" },
                  { "type": "null" }
                ]
              },
              "bid_window_days": {
                "oneOf": [
                  { "type": "integer", "minimum": 1 },
                  { "type": "null" }
                ]
              },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "notes": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [
              "project_id",
              "project_name",
              "contact_name",
              "contact_role",
              "confidence"
            ],
            "properties": {
              "project_id": { "type": "string", "minLength": 1 },
              "project_name": { "type": "string", "minLength": 1 },
              "contact_name": { "type": "string", "minLength": 1 },
              "contact_role": { "type": "string", "minLength": 1 },
              "company": { "type": "string" },
              "email": {
                "oneOf": [
                  { "type": "string", "format": "email" },
                  { "type": "null" }
                ]
              },
              "phone": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "null" }
                ]
              },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
