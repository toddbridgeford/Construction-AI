{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-ai.local/schemas/projects_schema.json",
  "title": "Construction AI Projects Feed",
  "type": "object",
  "required": ["version", "market", "generated_at", "projects"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "market": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "retrieved_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["project_id", "name", "stage", "location"],
        "properties": {
          "project_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "owner": { "type": "string" },
          "description": { "type": "string" },
          "stage": {
            "type": "string",
            "enum": [
              "planning",
              "design",
              "permitting",
              "pre_bid",
              "bidding",
              "awarded",
              "construction",
              "complete"
            ]
          },
          "location": {
            "type": "object",
            "required": ["city", "state"],
            "properties": {
              "city": { "type": "string", "minLength": 1 },
              "state": { "type": "string", "minLength": 2 },
              "address": { "type": "string" },
              "postal_code": { "type": "string" }
            },
            "additionalProperties": false
          },
          "trade_package": { "type": "string" },
          "contacts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "role"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "role": { "type": "string", "minLength": 1 },
                "company": { "type": "string" },
                "email": { "type": "string", "format": "email" },
                "phone": { "type": "string" }
              },
              "additionalProperties": false
            },
            "default": []
          },
          "procurement": {
            "type": "object",
            "properties": {
              "bid_date": { "type": "string", "format": "date" },
              "rfq_release_date": { "type": "string", "format": "date" },
              "permit_submission_date": { "type": "string", "format": "date" },
              "bid_window_days": { "type": "integer", "minimum": 1 },
              "delivery_method": { "type": "string" }
            },
            "additionalProperties": true
          },
          "budget": {
            "type": "object",
            "properties": {
              "low": { "type": "number", "minimum": 0 },
              "high": { "type": "number", "minimum": 0 },
              "currency": { "type": "string", "minLength": 3, "maxLength": 3 }
            },
            "additionalProperties": false
          },
          "meta": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
