{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-ai/schemas/deal_scoring_schema.json",
  "title": "Deal Scoring Artifact",
  "type": "object",
  "required": ["artifact_type", "market", "generated_at", "metadata", "items"],
  "properties": {
    "artifact_type": { "const": "deal_scoring" },
    "market": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "required": ["missing_inputs"],
      "properties": {
        "missing_inputs": { "type": "array", "items": { "type": "string" } },
        "details": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "project_id",
          "project_name",
          "deal_score",
          "component_scores",
          "rationale_bullets",
          "confidence",
          "verification_url"
        ],
        "properties": {
          "project_id": { "type": "string", "minLength": 1 },
          "project_name": { "type": "string" },
          "deal_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "component_scores": {
            "type": "object",
            "required": ["stage", "evidence", "trade_exposure", "proximity", "clarity", "risk_penalty"],
            "properties": {
              "stage": { "type": "integer" },
              "evidence": { "type": "integer" },
              "trade_exposure": { "type": "integer" },
              "proximity": { "type": "integer" },
              "clarity": { "type": "integer" },
              "risk_penalty": { "type": "integer" },
              "details": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": false
          },
          "rationale_bullets": {
            "type": "array",
            "maxItems": 6,
            "items": { "type": "string" }
          },
          "confidence": { "type": "string", "enum": ["High", "Medium", "Low"] },
          "verification_url": { "type": ["string", "null"] },
          "details": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
