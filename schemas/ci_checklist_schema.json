{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-ai.local/schemas/ci_checklist_schema.json",
  "title": "Construction Intelligence Checklist Schema",
  "type": "object",
  "required": ["version", "market", "title", "lens", "sections"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "market": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "lens": { "type": "string", "minLength": 1 },
    "decision_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_id", "question", "pass_condition", "fail_action"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "question": { "type": "string", "minLength": 1 },
          "pass_condition": { "type": "string", "minLength": 1 },
          "fail_action": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["section_id", "title", "objective", "checks"],
        "properties": {
          "section_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["check_id", "prompt", "required_evidence", "decision_logic"],
              "properties": {
                "check_id": { "type": "string", "minLength": 1 },
                "prompt": { "type": "string", "minLength": 1 },
                "required_evidence": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "decision_logic": { "type": "string", "minLength": 1 },
                "severity": {
                  "type": "string",
                  "enum": ["critical", "high", "medium", "low"]
                },
                "owner": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "nfpa_285_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assembly_family", "test_reference", "accepted_substitutions", "trigger"],
        "properties": {
          "assembly_family": { "type": "string", "minLength": 1 },
          "test_reference": { "type": "string", "minLength": 1 },
          "accepted_substitutions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "trigger": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
