{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://construction-intelligence/signal_api_v1.schema.json",
  "title": "Construction Intelligence Signal API v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "provenance",
    "indices",
    "ecosystem_pulse",
    "thermometer",
    "heatmap",
    "regime",
    "actions",
    "diagnostics"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "version", "mode", "run_date", "region"],
      "properties": {
        "system": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "const": "signal_api_v1" },
        "mode": { "type": "string", "enum": ["structural", "web_fetch", "data_assisted"] },
        "run_date": { "type": "string", "format": "date" },
        "region": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "geo_id"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "geo_id": { "type": ["string", "null"] }
          }
        }
      }
    },

    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["as_of", "sources"],
      "properties": {
        "as_of": { "type": "string", "format": "date" },
        "sources": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "series", "release_date", "last_updated", "url"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "series": { "type": "string", "minLength": 1 },
              "release_date": { "type": ["string", "null"], "format": "date" },
              "last_updated": { "type": ["string", "null"], "format": "date" },
              "url": { "type": ["string", "null"] }
            }
          }
        }
      }
    },

    "indices": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pressure_index",
        "capital_stress_index",
        "residential_index",
        "institutional_infra_index",
        "contractor_margin_index",
        "distributor_inventory_index",
        "manufacturer_pricing_index"
      ],
      "properties": {
        "pressure_index": { "$ref": "#/$defs/pressure_index" },
        "capital_stress_index": { "$ref": "#/$defs/simple_index" },
        "residential_index": {
          "type": "object",
          "additionalProperties": false,
          "required": ["value", "risk_state", "bifurcation"],
          "properties": {
            "value": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "risk_state": { "$ref": "#/$defs/risk_state" },
            "bifurcation": {
              "type": "object",
              "additionalProperties": false,
              "required": ["single_family", "multifamily"],
              "properties": {
                "single_family": { "$ref": "#/$defs/risk_state" },
                "multifamily": { "$ref": "#/$defs/risk_state" }
              }
            }
          }
        },
        "institutional_infra_index": { "$ref": "#/$defs/simple_index" },
        "contractor_margin_index": { "$ref": "#/$defs/simple_index" },
        "distributor_inventory_index": { "$ref": "#/$defs/simple_index" },
        "manufacturer_pricing_index": { "$ref": "#/$defs/simple_index" }
      }
    },

    "ecosystem_pulse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home_builders", "architects", "general_contractors", "distributors", "manufacturers"],
      "properties": {
        "home_builders": { "$ref": "#/$defs/risk_state" },
        "architects": { "$ref": "#/$defs/risk_state" },
        "general_contractors": { "$ref": "#/$defs/risk_state" },
        "distributors": { "$ref": "#/$defs/risk_state" },
        "manufacturers": { "$ref": "#/$defs/risk_state" }
      }
    },

    "thermometer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active", "trigger_reason", "display"],
      "properties": {
        "active": { "type": "boolean" },
        "trigger_reason": {
          "type": "array",
          "items": { "type": "string" }
        },
        "display": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cpi_value", "zone", "delta_3m", "risk_state"],
          "properties": {
            "cpi_value": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "zone": { "$ref": "#/$defs/zone" },
            "delta_3m": { "type": ["number", "null"] },
            "risk_state": { "$ref": "#/$defs/risk_state" }
          }
        }
      }
    },

    "heatmap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["as_of", "regions"],
      "properties": {
        "as_of": { "type": "string", "format": "date" },
        "regions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "velocity",
              "pressure",
              "capital",
              "residential",
              "institutional",
              "contractors",
              "distribution",
              "manufacturing"
            ],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "velocity": { "$ref": "#/$defs/direction" },
              "pressure": { "$ref": "#/$defs/risk_state" },
              "capital": { "$ref": "#/$defs/risk_state" },
              "residential": { "$ref": "#/$defs/risk_state" },
              "institutional": { "$ref": "#/$defs/risk_state" },
              "contractors": { "$ref": "#/$defs/risk_state" },
              "distribution": { "$ref": "#/$defs/risk_state" },
              "manufacturing": { "$ref": "#/$defs/risk_state" }
            }
          }
        }
      }
    },

    "regime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cycle_state", "modifier", "confidence", "inflection_triggers"],
      "properties": {
        "cycle_state": { "type": "string" },
        "modifier": { "type": "string" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "inflection_triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "condition", "active"],
            "properties": {
              "name": { "type": "string" },
              "condition": { "type": "string" },
              "active": { "type": "boolean" }
            }
          }
        }
      }
    },

    "actions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategic_posture", "decision_delta"],
      "properties": {
        "strategic_posture": { "type": "array", "items": { "type": "string" } },
        "decision_delta": { "type": "array", "items": { "type": "string" } }
      }
    },

    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["missing_inputs", "non_deterministic_blocks", "notes"],
      "properties": {
        "missing_inputs": { "type": "array", "items": { "type": "string" } },
        "non_deterministic_blocks": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  },

  "$defs": {
    "risk_state": { "type": "string", "enum": ["🟢", "🟡", "🔴"] },
    "direction": { "type": "string", "enum": ["↑", "↓", "→"] },
    "zone": {
      "type": ["string", "null"],
      "enum": [
        "Expansion Base",
        "Late Cycle Build",
        "Compression Phase",
        "Tightening Cycle",
        "Freeze Threshold",
        null
      ]
    },

    "simple_index": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "risk_state", "overlays"],
      "properties": {
        "value": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "risk_state": { "$ref": "#/$defs/risk_state" },
        "overlays": {
          "type": "object",
          "additionalProperties": false,
          "required": ["active_triggers", "overlay_points"],
          "properties": {
            "active_triggers": { "type": "array", "items": { "type": "string" } },
            "overlay_points": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        }
      }
    },

    "pressure_index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "direction",
        "zone",
        "delta_3m",
        "momentum_band",
        "risk_state",
        "drivers",
        "subindices",
        "divergences"
      ],
      "properties": {
        "value": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "direction": { "$ref": "#/$defs/direction" },
        "zone": { "$ref": "#/$defs/zone" },
        "delta_3m": { "type": ["number", "null"] },
        "momentum_band": {
          "type": "string",
          "enum": ["Stable", "Rising", "Accelerating Stress", "Easing", "Rapid Relief", "Unknown"]
        },
        "risk_state": { "$ref": "#/$defs/risk_state" },
        "drivers": {
          "type": "object",
          "additionalProperties": false,
          "required": ["capital", "pipeline", "trade", "materials", "regulatory", "macro"],
          "properties": {
            "capital": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "pipeline": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "trade": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "materials": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "regulatory": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "macro": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
          }
        },
        "subindices": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cpi_sf", "cpi_mf", "cpi_inst", "cpi_infra", "cpi_r", "cpi_i"],
          "properties": {
            "cpi_sf": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "cpi_mf": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "cpi_inst": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "cpi_infra": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "cpi_r": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
            "cpi_i": { "type": ["number", "null"], "minimum": 0, "maximum": 100 }
          }
        },
        "divergences": {
          "type": "object",
          "additionalProperties": false,
          "required": ["r_minus_i", "sf_minus_mf", "inst_minus_infra"],
          "properties": {
            "r_minus_i": { "type": ["number", "null"] },
            "sf_minus_mf": { "type": ["number", "null"] },
            "inst_minus_infra": { "type": ["number", "null"] }
          }
        }
      }
    }
  }
}